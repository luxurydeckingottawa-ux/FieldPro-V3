# ============================================================
# FieldPro V3 — Environment Variables Reference
# ============================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file with real values.
#
# VITE_ prefix = available in the browser bundle (public)
# No prefix    = server-side only (Netlify functions, never in browser)
# ============================================================

# ------------------------------------------------------------
# SUPABASE (required)
# Find these in: Supabase Dashboard → Settings → API
# ------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...                        # Public anon key — safe in browser

# ------------------------------------------------------------
# INTERNAL API SECURITY (required)
# Shared secret between frontend and Netlify functions.
# Generate with: node -e "console.log(require('crypto').randomUUID())"
# Both vars must have the SAME value.
# ------------------------------------------------------------
VITE_INTERNAL_API_SECRET=your-uuid-here              # Frontend sends this as X-Internal-Secret header
INTERNAL_API_SECRET=your-uuid-here                   # Functions validate against this

# ------------------------------------------------------------
# GEMINI AI (required for AI features)
# Server-side only — NEVER use VITE_ prefix for this key.
# Get from: https://aistudio.google.com/api-keys
# ------------------------------------------------------------
GEMINI_API_KEY=AIzaSy...

# ------------------------------------------------------------
# TWILIO — SMS (required for SMS features)
# Find these in: Twilio Console → Account Info
# ------------------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx                     # Your Twilio number in E.164 format

# ------------------------------------------------------------
# SENDGRID — Email (required for email features)
# Find these in: SendGrid → Settings → API Keys
# ------------------------------------------------------------
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=admin@yourdomain.com
SENDGRID_FROM_NAME=Your Company Name

# ------------------------------------------------------------
# CLOUDINARY — File storage (required for photo/PDF uploads)
# Find these in: Cloudinary Console → Dashboard
# ------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...                            # Server-side only — never expose in browser

# ------------------------------------------------------------
# ------------------------------------------------------------
# APP CONFIG
# ------------------------------------------------------------
VITE_OFFICE_EMAIL=admin@yourdomain.com               # Email for crew to submit completed jobs to

# ------------------------------------------------------------
# SENTRY — Error monitoring (optional but recommended)
# Find these in: Sentry → Project Settings → Client Keys
# ------------------------------------------------------------
VITE_SENTRY_DSN=https://...@sentry.io/...

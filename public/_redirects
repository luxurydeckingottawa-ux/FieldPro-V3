# InstaQuote lead capture endpoint — must be BEFORE the SPA catch-all.
# /api/instaquote-lead → Netlify function. The 200! status forces the
# proxy on ALL methods including POST (the netlify.toml [[redirects]]
# version was failing for POST bodies). The exclamation mark = "force"
# (overrides any other rule for this path).
/api/instaquote-lead    /.netlify/functions/instaquote-lead    200!

# SendGrid Event Webhook ingest. Same force-200 pattern so POST bodies pass.
/api/sendgrid-events    /.netlify/functions/sendgrid-events    200!

# Internal-only test cohort harness for the InstaQuote nurture sequence.
/api/instaquote-test-cohort    /.netlify/functions/instaquote-test-cohort    200!

# Real-time SendGrid open/click stats per recipient email.
# Used by the InstaQuote Blueprint card on the lead detail page.
/api/instaquote-email-stats    /.netlify/functions/instaquote-email-stats    200!

# SPA catch-all — every other request goes to the React shell.
/*    /index.html   200
